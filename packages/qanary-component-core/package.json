        "eslint-config-sdk": "*",
        "jest": "^29.4.1",
        "jest-config-sdk": "*",
        "ts-jest": "^29.2.5",
        "openapi-types": "12.1.3",
        "prettier": "^2.8.3",
        "prettier-config-sdk": "*",
        "rimraf": "^4.1.2",
        "ts-config-sdk": "*",
